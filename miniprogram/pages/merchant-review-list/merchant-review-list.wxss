/* 页面整体 */
page {
  background: #fff;
  height: 100%;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #fff;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  height: 44px;
  background: #fff;
  flex-shrink: 0;
  border-bottom: 1px solid #e5e5e5;
  position: relative;
  z-index: 10;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 17px;
  font-weight: 600;
  color: #000;
}

/* 状态筛选 */
.filter-bar {
  display: flex;
  justify-content: space-between;
  background: #fff;
  padding: 12px 20px;
  flex-shrink: 0;
  border-bottom: 1px solid #e5e5e5;
  box-shadow: 0 -6px 6px -6px #e5e5e5;
}

.filter-item {
  height: 32px;
  line-height: 32px;
  text-align: center;
  font-size: 13px;
  color: #666;
  background: #f5f5f5;
  padding: 0 20px;
  border-radius: 16px;
}

.filter-item.active {
  background: #07C160;
  color: #fff;
}

/* 统计卡片 */
.stats-cards {
  display: flex;
  justify-content: space-between;
  background: #fff;
  padding: 12px 16px;
  flex-shrink: 0;
}

.stats-card {
  flex: 1;
  height: 60px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  padding: 0 12px;
  border-radius: 8px;
  position: relative;
  margin: 0 8px;
}

.stats-card:first-child {
  margin-left: 0;
}

.stats-card:last-child {
  margin-right: 0;
}

.stats-card.pending::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 3px;
  height: 30px;
  background: #FF9500;
  border-radius: 0 2px 2px 0;
}

.stats-card.approved::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 3px;
  height: 30px;
  background: #07C160;
  border-radius: 0 2px 2px 0;
}

.stats-card.rejected::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 3px;
  height: 30px;
  background: #FF3B30;
  border-radius: 0 2px 2px 0;
}

.stats-num {
  font-size: 20px;
  font-weight: 600;
  color: #333;
}

.stats-label {
  font-size: 12px;
  color: #999;
  margin-top: 4px;
}

/* 列表滚动区域 */
.list-scroll {
  flex: 1;
  overflow: hidden;
  background: #fff;
  min-height: 0;
}

.list-container {
  padding: 12px 16px;
  background: #fff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 0;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.empty-text {
  font-size: 14px;
  color: #999;
}

/* 列表项 */
.list-item {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  border: 1rpx solid #f0f0f0;
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.item-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.item-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: #e8e8e8;
  flex-shrink: 0;
}

.item-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.item-nickname {
  font-size: 15px;
  font-weight: 500;
  color: #333;
}

.item-phone {
  font-size: 12px;
  color: #999;
  margin-top: 2px;
}

.item-status {
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 12px;
  flex-shrink: 0;
  white-space: nowrap;
}

.item-status.status-pending {
  background: #FFF3E0;
  color: #FF9500;
}

.item-status.status-approved {
  background: #E8F8EE;
  color: #07C160;
}

.item-status.status-rejected {
  background: #FFEBEA;
  color: #FF3B30;
}

/* 列表内容 */
.item-body {
  background: #f9f9f9;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
}

.item-company {
  display: flex;
  align-items: baseline;
  margin-bottom: 10px;
}

.item-contact {
  display: flex;
  align-items: baseline;
  margin-bottom: 6px;
}

.item-company-label,
.item-contact-label {
  font-size: 12px;
  color: #999;
  margin-right: 8px;
  flex-shrink: 0;
}

.item-company-name {
  font-size: 14px;
  color: #333;
  font-weight: 500;
}

.item-contact-value {
  font-size: 14px;
  color: #666;
}

.item-categories {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 8px;
}

.category-tag {
  font-size: 11px;
  color: #07C160;
  background: #E8F8EE;
  padding: 2px 8px;
  border-radius: 10px;
}

/* 列表底部 */
.item-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-time {
  font-size: 12px;
  color: #bbb;
}

.item-arrow {
  font-size: 18px;
  color: #ccc;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 20px 0;
  font-size: 13px;
  color: #999;
}
