/* 页面整体 */
page {
  background: #ffffff;
  height: 100%;
  overflow: hidden;
}

/* ========== 固定区域 ========== */
.fixed-top {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #f5f5f5;
  z-index: 100;
}

/* 导航栏 */
.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #e0e0e0;
  background: #ffffff;
}

.nav-title {
  font-size: 18px;
  font-weight: 600;
  color: #000;
}

/* ========== 未登录：会员卡风格 ========== */
.member-card {
  margin: 16px;
  padding: 28px 20px 20px;
  background: linear-gradient(135deg, #3a3f51 0%, #2d3142 100%);
  border-radius: 16px;
  position: relative;
}

.member-card-tag {
  position: absolute;
  top: 12px;
  right: 16px;
  font-size: 11px;
  color: rgba(255,255,255,0.6);
  border: 1px solid rgba(255,255,255,0.25);
  padding: 2px 10px;
  border-radius: 20px;
}

.member-card-body {
  display: flex;
  align-items: center;
  gap: 0;
  padding-top: 8px;
}

.member-card-body .avatar-btn {
  width: 50%;
}

.member-card-body .member-card-right {
  width: 50%;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  width: 100%;
  height: auto;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}
.avatar-btn::after {
  border: none;
}

.default-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  display: block;
  border: 2px solid rgba(255,255,255,0.2);
}

.member-card-center {
  flex: 1;
  min-width: 0;
}

.member-card-right {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.nickname-row {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.15);
  border-radius: 20px;
  padding: 8px 14px;
}

.nickname-label {
  font-size: 14px;
  color: rgba(255,255,255,0.6);
  margin-right: 8px;
  flex-shrink: 0;
}

.nickname-input {
  flex: 1;
  font-size: 14px;
  color: #fff;
  background: transparent;
  border: none;
  outline: none;
  min-width: 0;
}

.nickname-input::placeholder {
  color: rgba(255,255,255,0.4);
}

.login-btn {
  background: #07C160;
  color: white;
  font-size: 14px;
  padding: 8px 18px;
  border-radius: 20px;
  text-align: center;
  flex-shrink: 0;
}

/* ========== 四个数据卡片（关注/收藏/点赞/咨询） ========== */
.info-cards {
  margin: 0 16px;
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.info-card {
  width: calc(50% - 5px);
  background: white;
  border-radius: 12px;
  padding: 14px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.info-card-left {
  flex: 1;
}

.info-card-label {
  font-size: 13px;
  color: #333;
  display: block;
}

.info-card-num {
  font-size: 18px;
  font-weight: 600;
  color: #333;
}

.info-card-en {
  font-size: 10px;
  color: #bbb;
  letter-spacing: 1px;
  display: block;
  margin-top: 2px;
}

.info-card-icon {
  font-size: 24px;
  flex-shrink: 0;
}

.info-icon-blue { }
.info-icon-orange { }
.info-icon-red { }
.info-icon-purple { }

/* ========== 已登录：个人资料 ========== */
.profile-inner {
  padding: 20px 16px 16px;
  border-bottom: 1rpx solid #f0f0f0;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 16px;
}

.profile-avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  flex-shrink: 0;
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 20px;
  font-weight: 600;
  color: #000;
  margin-bottom: 6px;
  display: block;
}

.profile-mood {
  font-size: 12px;
  color: #999;
  display: block;
}

.profile-settings {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  flex-shrink: 0;
}

.settings-icon {
  font-size: 20px;
}

.profile-log {
  font-size: 12px;
  color: #666;
  line-height: 1.5;
  background: #f9f9f9;
  padding: 8px 10px;
  border-radius: 6px;
  margin-top: 12px;
}

.log-date {
  color: #999;
  font-size: 11px;
  margin-bottom: 4px;
  display: block;
}

.log-text {
  color: #333;
  display: block;
}

/* 统计数据 */
.profile-stats {
  display: flex;
  justify-content: space-around;
  padding: 16px 0 8px;
  background: white;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 4px;
  flex: 1;
  position: relative;
}

.stat-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 24px;
  background: #e0e0e0;
}

.stat-number {
  font-size: 18px;
  font-weight: 600;
  color: #000;
  margin-bottom: 4px;
}

.stat-label {
  font-size: 12px;
  color: #999;
}

/* ========== 未登录：9分类导航网格 ========== */
.guest-grid {
  background: white;
  margin: 10px 16px;
  border-radius: 12px;
  padding: 20px 8px 8px;
}

.guest-grid-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
}

.guest-grid-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20px;
}

.guest-grid-icon-wrap {
  width: 48px;
  height: 48px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8px;
}

.guest-grid-icon {
  font-size: 22px;
}

.guest-grid-name {
  font-size: 12px;
  color: #555;
  text-align: center;
}

/* ========== 可滚动区域 ========== */
.menu-scroll {
  background: #f5f5f5;
}

/* 已登录时的滚动区域背景 */
.menu-scroll[style*="background: #ffffff"] {
  background: #ffffff !important;
}

.menu-section {
  background: white;
  margin: 10px 16px;
  border-radius: 12px;
}

.menu-section-gap {
  height: 0;
}

.menu-list {
  padding: 0 16px;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.menu-icon {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  background: #f5f5f5;
  flex-shrink: 0;
}

.menu-label {
  font-size: 15px;
  color: #000;
}

.menu-count {
  font-size: 14px;
  color: #999;
  margin-left: 8px;
}

.menu-arrow {
  color: #999;
  font-size: 14px;
}

.menu-badge {
  background: #ff3b30;
  color: white;
  font-size: 11px;
  min-width: 18px;
  height: 18px;
  border-radius: 9px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 5px;
}

.safe-bottom {
  height: 20px;
}

.switch-role-btn {
  background: white;
}

.switch-role-btn:active {
  background: #f5f5f5;
}

/* ========== 商家模式样式 ========== */
.merchant-profile {
  padding: 20px 16px 16px;
}

.merchant-avatar-wrap {
  display: flex;
  align-items: center;
  gap: 16px;
}

.merchant-avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.merchant-avatar-text {
  font-size: 28px;
  font-weight: 600;
}

.merchant-info {
  flex: 1;
  min-width: 0;
}

.merchant-name-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.merchant-name {
  font-size: 20px;
  font-weight: 600;
  color: #000;
}

.merchant-verified {
  font-size: 11px;
  color: #07C160;
  background: #E8F8EE;
  padding: 2px 8px;
  border-radius: 10px;
}

.merchant-desc {
  font-size: 13px;
  color: #666;
  display: block;
}

.merchant-settings {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  flex-shrink: 0;
}

/* 商家动态日志 */
.merchant-log {
  font-size: 12px;
  color: #666;
  line-height: 1.5;
  background: #f9f9f9;
  padding: 8px 10px;
  border-radius: 6px;
  margin-top: 12px;
}

/* 商家统计数据（参照用户版格式） */
.merchant-stats {
  display: flex;
  justify-content: space-around;
  padding: 16px 0 8px;
  background: white;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}
