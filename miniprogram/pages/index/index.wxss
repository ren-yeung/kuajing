/* 页面整体 */
page {
  background: #f5f5f5;
  height: 100%;
  overflow: visible;
}

/* ========== 固定区域 ========== */
.fixed-top {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: white;
  z-index: 1000;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #e0e0e0;
}

.nav-title {
  font-size: 18px;
  font-weight: 600;
  color: #000;
}

/* 搜索栏 */
.search-section {
  padding: 8px 16px 12px;
}

.search-bar {
  background: #f5f5f5;
  border-radius: 8px;
  padding: 8px 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.search-icon {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
}

.search-placeholder {
  color: #999;
  font-size: 14px;
}

/* 分类导航 - 两行网格 */
.category-section {
  padding: 16rpx 16rpx 24rpx;
}

.category-section .category-list {
  display: flex;
  flex-wrap: wrap;
}

/* ========== 商家版需求分类导航 ========== */
.merchant-category {
  padding: 16rpx 16rpx 12rpx;
}

.merchant-category .category-list {
  display: flex;
  flex-wrap: wrap;
}

.merchant-category .category-item {
  width: 20%;
  margin-bottom: 20rpx;
}

.merchant-category .category-icon {
  width: 80rpx;
  height: 80rpx;
}

.merchant-category .category-name {
  font-size: 22rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: 20%;
  margin-bottom: 12rpx;
}

.category-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.category-name {
  font-size: 22rpx;
  color: #333;
}

/* 可滚动区域 - 白色背景 */
.service-scroll {
  background: white;
}

/* 推荐服务标题 - 固定区域内 */
.section-header {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 8px 16px 12px;
  background: white;
  border-bottom: none !important;
  box-shadow: none !important;
}

.section-title {
  font-size: 17px;
  font-weight: 600;
  color: #000;
}

.section-tab {
  font-size: 13px;
  color: #999;
}

.section-more {
  font-size: 13px;
  color: #999;
  margin-left: auto;
}

/* 服务卡片 */
.service-card {
  margin: 0 16px 16px 16px;
  background: white;
  border-radius: 16rpx;
  border: 0.5px solid #e0e0e0;
  overflow: hidden;
}

.card-inner {
  padding: 20rpx 24rpx;
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.service-image {
  width: 100px;
  height: 100px;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 12px;
  flex-shrink: 0;
}

.service-info {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* 服务信息头部：服务商+分类标签 */
.service-info-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.service-title {
  font-size: 16px;
  font-weight: 600;
  color: #000;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6px;
  display: block;
}

.service-provider {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.provider-avatar {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 500;
  flex-shrink: 0;
}

.provider-name {
  font-size: 13px;
  color: #666;
}

.provider-rating {
  font-size: 12px;
  color: #ff9500;
}

.service-desc {
  font-size: 13px;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8px;
  display: block;
}

/* 服务卡片底部：统计+咨询按钮 */
.service-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
}

.stats-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stat-item {
  font-size: 12px;
  color: #999;
}

.contact-btn {
  padding: 6px 16px;
  background: #07C160;
  color: white;
  border-radius: 14rpx;
  font-size: 13px;
}

/* ========== 需求卡片 ========== */
.category-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: #f0f9f0;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #07C160;
}

.category-tag.active {
  background: #07C160;
  color: white;
}

.demand-card {
  margin: 20rpx 28rpx 24rpx;
  background: white;
  border-radius: 16rpx;
  padding: 28rpx;
  border: 0.5px solid #e8e8e8;
}

/* 用户信息行 */
.demand-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.demand-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  font-weight: 600;
  margin-right: 12px;
  flex-shrink: 0;
}

.demand-user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.demand-user-name {
  font-size: 14px;
  font-weight: 500;
  color: #333;
}

.demand-post-time {
  font-size: 12px;
  color: #999;
}

/* 标题 */
.demand-title {
  font-size: 16px;
  font-weight: 600;
  color: #000;
  display: block;
  margin-bottom: 10rpx;
  line-height: 1.4;
}

/* 描述（最多2行） */
.demand-desc {
  font-size: 13px;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

/* 标签 */
.demand-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.demand-tag {
  padding: 6rpx 16rpx;
  background: #f5f7fa;
  border-radius: 6rpx;
  font-size: 12px;
  color: #555;
}

/* 预算 + 截止日期 行 */
.demand-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.demand-budget {
  font-size: 14px;
  font-weight: 600;
  color: #ff6b35;
}

.demand-deadline {
  font-size: 13px;
  color: #999;
}

/* 底部：统计 + 报名按钮 */
.demand-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.demand-stats {
  display: flex;
  gap: 20rpx;
}

.demand-stat {
  font-size: 12px;
  color: #888;
}

/* 立即报名按钮 - 绿色圆角 */
.apply-btn {
  padding: 8px 20px;
  background: #07C160;
  color: white;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 500;
}

/* 分类选中样式 */
.category-item.active .category-name {
  color: #07C160;
}

.category-item.active .category-icon {
  box-shadow: 0 2px 8px rgba(7, 193, 96, 0.3);
}

/* 空数据提示 */
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 14px;
}

/* 底部安全距离 */
.safe-bottom {
  height: 20px;
}

/* 悬浮发布按钮（可垂直拖动，bottom 由 inline style 动态设置） */
.fab-button {
  position: fixed;
  right: 20px;
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: #07C160;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 12px rgba(7, 193, 96, 0.4);
  z-index: 100;
}

.fab-icon {
  width: 24px;
  height: 24px;
}
