<view class="container" style="padding-top: {{statusBarHeight}}px;">
  <!-- 导航栏 -->
  <view class="nav-bar" style="height: {{navHeight}}px;">
    <text class="nav-title">商家审核</text>
  </view>

  <!-- 状态筛选 -->
  <view class="filter-bar">
    <view 
      class="filter-item {{currentFilter === 'all' ? 'active' : ''}}" 
      bindtap="onFilterChange" 
      data-filter="all"
    >
      全部
    </view>
    <view 
      class="filter-item {{currentFilter === 'pending' ? 'active' : ''}}" 
      bindtap="onFilterChange" 
      data-filter="pending"
    >
      待审核
    </view>
    <view 
      class="filter-item {{currentFilter === 'approved' ? 'active' : ''}}" 
      bindtap="onFilterChange" 
      data-filter="approved"
    >
      已通过
    </view>
    <view 
      class="filter-item {{currentFilter === 'rejected' ? 'active' : ''}}" 
      bindtap="onFilterChange" 
      data-filter="rejected"
    >
      已拒绝
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-cards">
    <view class="stats-card pending">
      <text class="stats-num">{{stats.pending}}</text>
      <text class="stats-label">待审核</text>
    </view>
    <view class="stats-card approved">
      <text class="stats-num">{{stats.approved}}</text>
      <text class="stats-label">已通过</text>
    </view>
    <view class="stats-card rejected">
      <text class="stats-num">{{stats.rejected}}</text>
      <text class="stats-label">已拒绝</text>
    </view>
  </view>

  <!-- 申请列表 -->
  <scroll-view
    class="list-scroll"
    scroll-y
    bindscrolltolower="onLoadMore"
    enhanced
    show-scrollbar="{{false}}"
    style="height: calc(100vh - {{statusBarHeight}}px - 44px - 48px - 84px);"
  >
    <view class="list-container">
      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{!loading && list.length === 0}}">
        <text class="empty-icon">📋</text>
        <text class="empty-text">暂无申请记录</text>
      </view>

      <!-- 列表项 -->
      <view 
        class="list-item" 
        wx:for="{{list}}" 
        wx:key="_id"
        bindtap="goToDetail"
        data-id="{{item._id}}"
      >
        <view class="item-header">
          <view class="item-left">
            <image 
              class="item-avatar" 
              src="{{item.userAvatar || '/images/avatar.png'}}" 
              mode="aspectFill"
            ></image>
            <view class="item-info">
              <text class="item-nickname">{{item.userNickname || '微信用户'}}</text>
              <text class="item-phone">{{item.userPhone || '未绑定手机'}}</text>
            </view>
          </view>
          <view class="item-status status-{{item.status}}">
            <text wx:if="{{item.status === 'pending'}}">待审核</text>
            <text wx:elif="{{item.status === 'approved'}}">已通过</text>
            <text wx:elif="{{item.status === 'rejected'}}">已拒绝</text>
          </view>
        </view>

        <view class="item-body">
          <view class="item-company">
            <text class="item-company-label">公司名称</text>
            <text class="item-company-name">{{item.companyName}}</text>
          </view>
          <view class="item-contact">
            <text class="item-contact-label">联系方式</text>
            <text class="item-contact-value">{{item.contactName}} {{item.contactPhone}}</text>
          </view>
          <view class="item-categories" wx:if="{{item.categories.length > 0}}">
            <text class="category-tag" wx:for="{{item.categories}}" wx:for-item="cat" wx:key="{{cat}}">{{cat}}</text>
          </view>
        </view>

        <view class="item-footer">
          <text class="item-time">{{item.createTimeStr}}</text>
          <text class="item-arrow">›</text>
        </view>
      </view>

      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{list.length > 0}}">
        <text wx:if="{{loading}}">加载中...</text>
        <text wx:elif="{{noMore}}">— 没有更多了 —</text>
      </view>
    </view>
  </scroll-view>
</view>
