/* 页面整体 */
page {
  background: #f5f5f5;
  height: 100vh;
}

/* ========== 导航栏 ========== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: white;
  z-index: 100;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 16px;
  border-bottom: 1rpx solid #e0e0e0;
}

.nav-back {
  display: flex;
  align-items: center;
  gap: 4px;
  padding-right: 12px;
}

.back-arrow {
  font-size: 24px;
  color: #000;
  line-height: 1;
}

.back-text {
  font-size: 15px;
  color: #000;
}

.nav-title {
  font-size: 18px;
  font-weight: 600;
  color: #000;
  flex: 1;
  text-align: center;
}

.nav-right-placeholder {
  width: 60px;
}

/* ========== 可滚动区域：表单 ========== */
.form-scroll {
  background: white;
}

.form-group {
  padding: 16px;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-label {
  font-size: 14px;
  font-weight: 500;
  color: #333;
  margin-bottom: 8px;
  display: block;
}

.required::after {
  content: ' *';
  color: #ff3b30;
}

.form-input {
  width: 100%;
  padding: 12px 12px;
  border: 1rpx solid #e0e0e0;
  border-radius: 8px;
  font-size: 14px;
  color: #333;
  background: white;
  box-sizing: border-box;
  min-height: 44px;
}

.form-input::placeholder {
  color: #999;
}

.form-textarea {
  width: 100%;
  padding: 10px 12px;
  border: 1rpx solid #e0e0e0;
  border-radius: 8px;
  font-size: 14px;
  color: #333;
  background: white;
  min-height: 56px;
  box-sizing: border-box;
}

.form-textarea::placeholder {
  color: #999;
}

/* 分类选择 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

.category-option {
  padding: 10px;
  border: 1rpx solid #e0e0e0;
  border-radius: 8px;
  text-align: center;
  font-size: 13px;
  color: #666;
  background: white;
}

.category-option.selected {
  background: #07C160;
  color: white;
  border-color: #07C160;
}

/* 提交按钮 */
.submit-btn {
  margin: 20px 16px;
  padding: 12px;
  background: #07C160;
  color: white;
  border: none;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 500;
  width: calc(100% - 32px);
}

/* 底部固定按钮栏 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  background: white;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.05);
  z-index: 100;
}

/* 底部安全距离 */
.safe-bottom {
  height: 20px;
}
