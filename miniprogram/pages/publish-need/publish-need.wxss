/* 页面整体 */
page {
  background: #f5f5f5;
  height: 100vh;
}

/* ========== 导航栏 ========== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: white;
  z-index: 100;
}

.nav-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.nav-back {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding-right: 24rpx;
}

.back-arrow {
  font-size: 48rpx;
  color: #000;
  line-height: 1;
}

.back-text {
  font-size: 30rpx;
  color: #000;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #000;
  flex: 1;
  text-align: center;
}

.nav-right-placeholder {
  width: 120rpx;
}

/* ========== 可滚动区域：表单 ========== */
.form-scroll {
  background: white;
}

.form-group {
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.required::after {
  content: ' *';
  color: #ff3b30;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  background: white;
  box-sizing: border-box;
  min-height: 88rpx;
}

.form-input::placeholder {
  color: #999;
}

.form-textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  background: white;
  min-height: 112rpx;
  box-sizing: border-box;
}

.form-textarea::placeholder {
  color: #999;
}

/* 分类选择 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.category-option {
  padding: 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  background: white;
}

.category-option.selected {
  background: #07C160;
  color: white;
  border-color: #07C160;
}

/* 预算范围 */
.budget-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.budget-input {
  flex: 1;
}

.budget-separator {
  color: #999;
  font-size: 28rpx;
}

/* 标签选择 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 12rpx 28rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: white;
}

.tag-selected {
  background: rgba(7, 193, 96, 0.1);
  border-color: #07C160;
  color: #07C160;
}

/* 日期选择器 */
.picker-display {
  padding: 24rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  background: white;
}

.picker-display.placeholder {
  color: #999;
}

/* 提交按钮 */
.submit-btn {
  margin: 0;
  padding: 24rpx;
  background: #07C160;
  color: white;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  width: 100%;
}

/* 底部固定按钮栏 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: white;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}
