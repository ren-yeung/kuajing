.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 116rpx;
  background: white;
  border-top: 1rpx solid #e0e0e0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  position: relative;
}

.tab-icon {
  font-size: 48rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-label {
  font-size: 20rpx;
  font-weight: 500;
  color: #999;
}

.tab-item.active .tab-label {
  color: #07C160;
}

.notification-dot {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  z-index: 10;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: #ff3b30;
  border-radius: 50%;
  border: 3rpx solid white;
}
