<!-- 导航栏 -->
<view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
  <view class="nav-content">
    <view class="nav-left"></view>
    <text class="nav-title">商家主页</text>
    <view class="nav-right"></view>
  </view>
</view>

<!-- 占位：顶出导航栏高度 -->
<view style="height: {{navHeight}}px;"></view>

<!-- 页面容器 -->
<view class="page-container">
  
  <!-- 固定区域：头像 + 统计 -->
  <view class="profile-sticky">
    <!-- 个人资料区域 -->
    <view class="profile-section">
      <view class="profile-inner">
        <!-- 头像 + 名称 -->
        <view class="profile-header">
          <view class="avatar-wrapper">
            <view class="profile-avatar" style="background: {{merchantInfo.avatarBg || 'linear-gradient(135deg, #FF9A8B 0%, #FE6E9A 100%)'}};">
              <text>{{merchantInfo.avatarText || '商'}}</text>
            </view>
            <view class="verified-check" wx:if="{{merchantInfo.isVerified}}">
              <text>✓</text>
            </view>
          </view>
          <view class="profile-info">
            <view class="profile-name-row">
              <text class="profile-name">{{merchantInfo.name || '商家名称'}}</text>
              <text class="verified-tag" wx:if="{{merchantInfo.merchantStatus === 'approved'}}">已认证</text>
            </view>
            <text class="profile-mood">{{merchantInfo.description || '专业海外仓—件代发'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 统计数据 -->
    <view class="stats-section">
      <view class="stats-divider-line"></view>
      <view class="profile-stats">
        <view class="stat-item" bindtap="onStatTap" data-type="fans">
          <text class="stat-number">{{merchantInfo.fans || 0}}</text>
          <text class="stat-label">粉丝</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item" bindtap="onStatTap" data-type="likes">
          <text class="stat-number">{{merchantInfo.likes || 0}}</text>
          <text class="stat-label">获赞</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item" bindtap="onStatTap" data-type="deals">
          <text class="stat-number">{{merchantInfo.deals || 0}}</text>
          <text class="stat-label">已成交</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item" bindtap="onStatTap" data-type="rating">
          <text class="stat-number">{{merchantInfo.rating || '5.0'}}</text>
          <text class="stat-label">评分</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 可滚动内容区域 -->
  <scroll-view scroll-y class="menu-scroll" enhanced show-scrollbar="{{false}}" style="top: calc({{navHeight}}px + {{profileHeight}}px); bottom: calc(110rpx + {{safeBottom}}px);">
    
    <!-- 第一组菜单 -->
    <view class="menu-section">
      <view class="menu-list">
        <view class="menu-item" bindtap="onMenuTap" data-type="my-services">
          <view class="menu-left">
            <text class="menu-icon">📦</text>
            <text class="menu-label">我的服务</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onMenuTap" data-type="service-orders">
          <view class="menu-left">
            <text class="menu-icon">📋</text>
            <text class="menu-label">服务订单</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onMenuTap" data-type="reviews">
          <view class="menu-left">
            <text class="menu-icon">⭐</text>
            <text class="menu-label">评价管理</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="menu-section-gap"></view>

    <!-- 第二组菜单 -->
    <view class="menu-section">
      <view class="menu-list">
        <view class="menu-item" bindtap="onMenuTap" data-type="statistics">
          <view class="menu-left">
            <text class="menu-icon">📊</text>
            <text class="menu-label">数据统计</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onMenuTap" data-type="messages">
          <view class="menu-left">
            <text class="menu-icon">💬</text>
            <text class="menu-label">我的消息</text>
          </view>
          <view style="display: flex; align-items: center; gap: 8px;">
            <view class="menu-badge" wx:if="{{unreadCount > 0}}">{{unreadCount > 99 ? '99+' : unreadCount}}</view>
            <text class="menu-arrow">›</text>
          </view>
        </view>
        <view class="menu-item" bindtap="onMenuTap" data-type="notifications">
          <view class="menu-left">
            <text class="menu-icon">🔔</text>
            <text class="menu-label">系统通知</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="menu-section-gap"></view>

    <!-- 第三组菜单 -->
    <view class="menu-section">
      <view class="menu-list">
        <view class="menu-item" bindtap="onMenuTap" data-type="edit-profile">
          <view class="menu-left">
            <text class="menu-icon">👤</text>
            <text class="menu-label">编辑资料</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onMenuTap" data-type="merchant-auth">
          <view class="menu-left">
            <text class="menu-icon">🏅</text>
            <text class="menu-label">商家认证</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onMenuTap" data-type="help">
          <view class="menu-left">
            <text class="menu-icon">❓</text>
            <text class="menu-label">帮助与反馈</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="switchToUser">
          <view class="menu-left">
            <text class="menu-icon">👤</text>
            <text class="menu-label">切换个人用户</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 底部安全距离 -->
    <view class="safe-bottom"></view>

  </scroll-view>

</view>

<!-- 底部TabBar -->
<view class="tab-bar" style="padding-bottom: {{safeBottom}}px;">
  <view class="tab-item" bindtap="goHome">
    <view class="tab-icon-wrap">
      <text class="tab-icon">🏠</text>
    </view>
    <text class="tab-text">首页</text>
  </view>
  <view class="tab-item" bindtap="goMessages">
    <view class="tab-icon-wrap tab-msg">
      <text class="tab-icon">💬</text>
    </view>
    <text class="tab-text">消息</text>
  </view>
  <view class="tab-item tab-active" bindtap="goToProfile">
    <view class="tab-icon-wrap">
      <text class="tab-icon tab-icon-active">👤</text>
    </view>
    <text class="tab-text tab-text-active">我的</text>
  </view>
</view>
