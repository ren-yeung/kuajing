/* ========== 页面整体 ========== */
page {
  background: #ffffff;
  height: 100vh;
}

/* ========== 页面容器 ========== */
.page-container {
  display: flex;
  flex-direction: column;
  height: calc(100vh - 110rpx);
  overflow: hidden;
}

/* ========== 导航栏 ========== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: white;
  z-index: 100;
}

.nav-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
}

.nav-left {
  width: 80rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #000;
  flex: 1;
  text-align: center;
}

.nav-right {
  width: 80rpx;
}

/* ========== 固定区域 ========== */
.profile-sticky {
  background: white;
  flex-shrink: 0;
}

/* ========== 个人资料区域 ========== */
.profile-section {
  background: white;
}

.profile-inner {
  padding: 35rpx 32rpx 25rpx;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

/* 头像 - 粉色渐变圆 + 右下绿勾 */
.avatar-wrapper {
  position: relative;
  flex-shrink: 0;
}

.profile-avatar {
  width: 125rpx;
  height: 125rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9A8B 0%, #FE6E9A 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  font-weight: 600;
  color: white;
}

.verified-check {
  position: absolute;
  bottom: -2rpx;
  right: -2rpx;
  width: 38rpx;
  height: 38rpx;
  background: #07C160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid white;
  box-sizing: border-box;
}

.verified-check text {
  font-size: 22rpx;
  color: white;
  line-height: 1;
  font-weight: bold;
}

/* 名称信息 */
.profile-info {
  flex: 1;
}

.profile-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.profile-name {
  font-size: 42rpx;
  font-weight: 600;
  color: #000;
}

.verified-tag {
  font-size: 28rpx;
  background: #07C160;
  color: white;
  padding: 5rpx 18rpx;
  border-radius: 8rpx;
  font-weight: 500;
  line-height: 1.5;
}

.profile-mood {
  font-size: 31rpx;
  color: #999;
}

/* ========== 统计数据 ========== */
.stats-section {
  background: white;
}

.stats-divider-line {
  height: 1rpx;
  background: #f0f0f0;
  margin: 0 32rpx;
}

.profile-stats {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-number {
  font-size: 38rpx;
  font-weight: 700;
  color: #111;
  line-height: 1.3;
}

.stat-label {
  font-size: 29rpx;
  color: #999;
  margin-top: 5rpx;
}

.stat-divider {
  width: 1rpx;
  height: 36rpx;
  background: #e5e5e5;
}

/* ========== 可滚动菜单区域 ========== */
.menu-scroll {
  position: fixed;
  left: 0;
  right: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  z-index: 40;
  background: #ffffff;
}

.menu-scroll::-webkit-scrollbar {
  display: none;
}

/* ========== 菜单列表 ========== */
.menu-section {
  background: white;
  margin: 20rpx 32rpx;
  border-radius: 24rpx;
}

.menu-section-gap {
  height: 0;
}

.safe-bottom {
  height: 16rpx;
}

.menu-list {
  padding: 0 32rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.menu-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  width: auto;
  height: auto;
  background: transparent;
  border-radius: 0;
  display: inline;
}

.menu-label {
  font-size: 30rpx;
  color: #000;
  font-weight: 400;
}

.menu-right-area {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.menu-arrow {
  color: #999;
  font-size: 30rpx;
}

.menu-badge {
  background: #ff3b30;
  color: white;
  font-size: 22rpx;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  font-weight: 500;
}

.menu-badge {
  background: #ff3b30;
  color: white;
  font-size: 22rpx;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  font-weight: 500;
}

/* ========== 底部TabBar ========== */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: white;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-top: 1rpx solid #eee;
  z-index: 99;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 40rpx;
}

.tab-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  font-size: 40rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #999;
}

.tab-active .tab-text {
  color: #07C160;
  font-weight: 600;
}
