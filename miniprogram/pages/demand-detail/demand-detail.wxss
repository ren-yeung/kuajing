/* demand-detail.wxss */
page {
  height: 100%;
  background: #fff;
}

.page {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background: #fff;
  overflow: hidden;
}

/* 加载中提示 */
.loading-cover {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E5E5E5;
  border-top-color: #07C160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ========== 导航栏 ========== */
.nav-bar {
  position: fixed;
  top: 88rpx;
  left: 0;
  right: 0;
  background: white;
  z-index: 100;
  border-bottom: 1rpx solid #e0e0e0;
}

.nav-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.nav-back {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding-right: 24rpx;
}

.back-arrow {
  font-size: 48rpx;
  color: #000;
  line-height: 1;
}

.back-text {
  font-size: 30rpx;
  color: #000;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #000;
  flex: 1;
  text-align: center;
}

.nav-right-placeholder {
  width: 120rpx;
}

/* ========== 滚动内容区域 ========== */
.content-scroll {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  background: #fff;
}

.content-scroll::-webkit-scrollbar {
  display: none;
}

/* 需求信息卡片 */
.demand-info-card {
  background: white;
  padding: 32rpx;
}

.demand-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.demand-status {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.demand-category {
  font-size: 24rpx;
  color: #666;
}

.demand-category.selected {
  padding: 8rpx 16rpx;
  background: rgba(7, 193, 96, 0.1);
  border: 1rpx solid #07C160;
  border-radius: 8rpx;
  color: #07C160;
}

.demand-title {
  font-size: 38rpx;
  font-weight: 600;
  color: #000;
  margin-bottom: 24rpx;
  display: block;
  line-height: 1.4;
}

.demand-budget-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  flex-wrap: wrap;
}

.budget-info {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.budget-label {
  font-size: 28rpx;
  color: #666;
}

.budget-amount {
  font-size: 40rpx;
  font-weight: 600;
  color: #ff6b35;
  margin-left: 8rpx;
}

.deadline {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 浏览/报名统计 */
.stats-row {
  display: flex;
  gap: 48rpx;
  background: white;
  padding: 0 32rpx 24rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #999;
}

/* 发布者信息 */
.user-section {
  background: white;
  margin-top: 16rpx;
  padding: 32rpx;
  padding-top: 40rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-top: 1rpx solid #e0e0e0;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.user-avatar-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.user-avatar-text {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #000;
  margin-bottom: 8rpx;
}

.post-time {
  font-size: 24rpx;
  color: #999;
}

/* 需求详情 */
.detail-section {
  background: white;
  margin-top: 24rpx;
  margin-left: 24rpx;
  margin-right: 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e0e0e0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.detail-title-row {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #000;
  display: block;
}

.detail-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.7;
  white-space: pre-wrap;
}

/* 需求标签 - 灰色胶囊样式 */
.detail-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.detail-tag {
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666;
}

/* 需求地区 */
.region-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
}

.region-icon {
  font-size: 28rpx;
}

.region-text {
  font-size: 28rpx;
  color: #666;
}

/* 联系电话 */
.phone-section {
  background: white;
  margin-top: 16rpx;
  padding: 24rpx 32rpx;
}

.phone-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.phone-icon {
  font-size: 28rpx;
}

.phone-text {
  font-size: 28rpx;
  color: #666;
}

/* 报名商家列表 */
.merchants-section {
  background: white;
  margin-top: 12rpx;
  padding: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.more-link {
  font-size: 26rpx;
  color: #07C160;
}

.merchant-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.merchant-card:last-child {
  border-bottom: none;
}

.merchant-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.merchant-info {
  flex: 1;
  min-width: 0;
}

.merchant-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #000;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.verified-badge {
  font-size: 20rpx;
  background: #07C160;
  color: white;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.merchant-rating {
  font-size: 24rpx;
  color: #ff9500;
  margin-bottom: 8rpx;
}

.merchant-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.merchant-arrow {
  font-size: 48rpx;
  color: #ccc;
  font-weight: 300;
  flex-shrink: 0;
  padding: 0 8rpx;
}

.empty-merchants {
  text-align: center;
  padding: 48rpx;
  color: #999;
  font-size: 28rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  gap: 24rpx;
  z-index: 100;
}

.bottom-left {
  display: flex;
  gap: 32rpx;
}

.bottom-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.bottom-action-icon {
  font-size: 40rpx;
}

.bottom-action-text {
  font-size: 20rpx;
  color: #999;
}

.apply-btn-bar {
  flex: 1;
  padding: 24rpx;
  background: #07C160;
  color: white;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.apply-btn-bar.applied {
  background: #f5f5f5;
  color: #999;
}
