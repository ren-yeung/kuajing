<!-- 固定区域：个人资料 + 统计 -->
<view class="fixed-top" style="padding-top: {{statusBarHeight}}px; background: {{isLoggedIn ? '#ffffff' : '#f5f5f5'}};">
  <!-- 导航栏（在固定区域内） -->
  <view class="nav-content">
    <text class="nav-title">{{currentRole === 'merchant' ? '商家主页' : '个人主页'}}</text>
  </view>

  <!-- 未登录：会员卡风格引导登录 -->
  <view class="member-card" wx:if="{{!isLoggedIn}}">
    <view class="member-card-body">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="default-avatar" src="{{pendingAvatar || '/images/avatar.png'}}" mode="aspectFill"></image>
      </button>
      <view class="member-card-right">
        <view class="nickname-row">
          <text class="nickname-label">昵称</text>
          <input 
            class="nickname-input" 
            type="nickname" 
            placeholder="点击设置昵称" 
            value="{{nickname}}"
            bindinput="onNicknameInput"
            bindblur="onNicknameBlur"
          />
        </view>
        <view class="login-btn" bindtap="onLogin">登录</view>
      </view>
    </view>
  </view>

  <!-- 已登录：用户模式 -->
  <view wx:elif="{{isLoggedIn && currentRole === 'user'}}">
    <view class="profile-inner">
      <view class="profile-header">
        <image class="profile-avatar" src="{{userInfo.avatar}}" bindtap="onChooseLocalImage"></image>
        <view class="profile-info">
          <text class="profile-name">{{userInfo.nickname}}</text>
          <text class="profile-mood">{{mood}}</text>
        </view>
        <view class="profile-settings" bindtap="goPage" data-page="settings">
          <text class="settings-icon">⚙️</text>
        </view>
      </view>

      <view class="profile-log">
        <view class="log-date">{{logDate}}</view>
        <view class="log-text">{{logText}}</view>
      </view>
    </view>

    <view class="profile-stats">
      <view class="stat-item">
        <text class="stat-number">{{stats.publish}}</text>
        <text class="stat-label">发布需求</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.consult}}</text>
        <text class="stat-label">咨询商家</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.cooperate}}</text>
        <text class="stat-label">成功合作</text>
      </view>
    </view>
  </view>

  <!-- 已登录：商家模式 -->
  <view wx:elif="{{isLoggedIn && currentRole === 'merchant'}}">
    <view class="merchant-profile">
      <view class="merchant-avatar-wrap">
        <view class="merchant-avatar" style="background: {{merchantInfo.avatarBg}};">
          <text class="merchant-avatar-text" style="color: {{merchantInfo.avatarColor}};">{{merchantInfo.avatarText}}</text>
        </view>
        <view class="merchant-info">
          <view class="merchant-name-row">
            <text class="merchant-name">{{merchantInfo.name}}</text>
            <view class="merchant-verified" wx:if="{{merchantInfo.isVerified}}">✓ 已认证</view>
          </view>
          <text class="merchant-desc">{{merchantInfo.description}}</text>
        </view>
        <view class="merchant-settings" bindtap="goPage" data-page="settings">
          <text class="settings-icon">⚙️</text>
        </view>
      </view>

      <!-- 商家动态日志 -->
      <view class="merchant-log">
        <view class="log-date">{{logDate}}</view>
        <view class="log-text">{{merchantLogText}}</view>
      </view>
    </view>

    <!-- 商家统计数据（参照用户版格式） -->
    <view class="merchant-stats">
      <view class="stat-item" bindtap="onStatTap" data-type="fans">
        <text class="stat-number">{{merchantInfo.fans}}</text>
        <text class="stat-label">粉丝</text>
      </view>
      <view class="stat-item" bindtap="onStatTap" data-type="likes">
        <text class="stat-number">{{merchantInfo.likes}}</text>
        <text class="stat-label">获赞</text>
      </view>
      <view class="stat-item" bindtap="onStatTap" data-type="deals">
        <text class="stat-number">{{merchantInfo.deals}}</text>
        <text class="stat-label">成交</text>
      </view>
      <view class="stat-item" bindtap="onStatTap" data-type="rating">
        <text class="stat-number">{{merchantInfo.rating}}</text>
        <text class="stat-label">评分</text>
      </view>
    </view>
  </view>

  <!-- 四个数据卡片（关注、收藏、点赞、咨询）- 仅未登录显示 -->
  <view class="info-cards" wx:if="{{!isLoggedIn}}" style="margin-top: 8px;">
    <view class="info-card" bindtap="onLogin">
      <view class="info-card-left">
        <text class="info-card-label">关注：<text class="info-card-num">0</text></text>
        <text class="info-card-en">FOLLOW</text>
      </view>
      <text class="info-card-icon info-icon-blue">👁️</text>
    </view>
    <view class="info-card" bindtap="onLogin">
      <view class="info-card-left">
        <text class="info-card-label">收藏：<text class="info-card-num">0</text></text>
        <text class="info-card-en">COLLECTION</text>
      </view>
      <text class="info-card-icon info-icon-orange">⭐</text>
    </view>
    <view class="info-card" bindtap="onLogin">
      <view class="info-card-left">
        <text class="info-card-label">点赞：<text class="info-card-num">0</text></text>
        <text class="info-card-en">LIKE</text>
      </view>
      <text class="info-card-icon info-icon-red">❤️</text>
    </view>
    <view class="info-card" bindtap="onLogin">
      <view class="info-card-left">
        <text class="info-card-label">咨询：<text class="info-card-num">0</text></text>
        <text class="info-card-en">CONSULT</text>
      </view>
      <text class="info-card-icon info-icon-purple">💬</text>
    </view>
  </view>

  <!-- 未登录：9个分类导航网格 -->
  <view class="guest-grid" wx:if="{{!isLoggedIn}}" style="margin: 12px 16px;">
    <view class="guest-grid-list">
      <view class="guest-grid-item"
            wx:for="{{guestCategories}}"
            wx:key="id"
            bindtap="onGuestCategoryTap">
        <view class="guest-grid-icon-wrap" style="background: {{item.bgColor}};">
          <text class="guest-grid-icon">{{item.icon}}</text>
        </view>
        <text class="guest-grid-name">{{item.name}}</text>
      </view>
    </view>
  </view>
</view>

<!-- 可滚动区域 -->
<scroll-view
  class="menu-scroll"
  scroll-y
  enhanced
  show-scrollbar="{{false}}"
  scroll-top="{{menuScrollTop}}"
  style="position: fixed; top: {{fixedTopHeight}}px; height: calc(100vh - {{fixedTopHeight}}px - {{tabBarOuterHeight}}px); width: 100%; background: {{isLoggedIn ? '#ffffff' : '#f5f5f5'}};"
>
  <!-- 已登录：完整菜单列表 -->
  <block wx:if="{{isLoggedIn}}">
    <!-- 第一组：我的发布、我的点赞、我的收藏、浏览历史 -->
    <view class="menu-section">
      <view class="menu-list">
        <view class="menu-item" bindtap="goPage" data-page="myPosts">
          <view class="menu-left">
            <view class="menu-icon">📝</view>
            <text class="menu-label">我的发布</text>
            <text class="menu-count">{{stats.publish || 0}}篇</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goPage" data-page="myLikes">
          <view class="menu-left">
            <view class="menu-icon">❤️</view>
            <text class="menu-label">我的点赞</text>
            <text class="menu-count">28篇</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goPage" data-page="myFavorites">
          <view class="menu-left">
            <view class="menu-icon">⭐</view>
            <text class="menu-label">我的收藏</text>
            <text class="menu-count">15篇</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goPage" data-page="history">
          <view class="menu-left">
            <view class="menu-icon">📱</view>
            <text class="menu-label">浏览历史</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="menu-section-gap"></view>

    <!-- 第二组：我的消息、系统通知 -->
    <view class="menu-section">
      <view class="menu-list">
        <view class="menu-item" bindtap="goPage" data-page="myMessages">
          <view class="menu-left">
            <view class="menu-icon">💬</view>
            <text class="menu-label">我的消息</text>
          </view>
          <view style="display: flex; align-items: center; gap: 8px;">
            <view class="menu-badge" wx:if="{{unreadCount > 0}}">{{unreadCount}}</view>
            <text class="menu-arrow">›</text>
          </view>
        </view>
        <view class="menu-item" bindtap="goPage" data-page="notifications">
          <view class="menu-left">
            <view class="menu-icon">🔔</view>
            <text class="menu-label">系统通知</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="menu-section-gap"></view>

    <!-- 第三组：编辑资料、隐私设置、帮助与反馈、成为商家 -->
    <view class="menu-section">
      <view class="menu-list">
        <view class="menu-item" bindtap="goPage" data-page="editProfile">
          <view class="menu-left">
            <view class="menu-icon">👤</view>
            <text class="menu-label">编辑资料</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goPage" data-page="privacy">
          <view class="menu-left">
            <view class="menu-icon">🔒</view>
            <text class="menu-label">隐私设置</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goPage" data-page="help">
          <view class="menu-left">
            <view class="menu-icon">❓</view>
            <text class="menu-label">帮助与反馈</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
        <!-- 根据身份状态显示不同按钮 -->
        <block wx:if="{{isLoggedIn}}">
          <view class="menu-item" wx:if="{{currentRole === 'user'}}" bindtap="onSwitchRole">
            <view class="menu-left">
              <view class="menu-icon" style="background: #FFF3E0;">🔄</view>
              <text class="menu-label">切换商家版</text>
            </view>
            <text class="menu-arrow">›</text>
          </view>
          <view class="menu-item switch-role-btn" wx:if="{{currentRole === 'merchant'}}" bindtap="onSwitchRole">
            <view class="menu-left">
              <view class="menu-icon" style="background: #F5F5F5;">🔄</view>
              <text class="menu-label">切换用户版</text>
            </view>
            <text class="menu-arrow">›</text>
          </view>
        </block>
        <!-- 已登录才显示退出登录 -->
        <view class="menu-item" bindtap="onLogout">
          <view class="menu-left">
            <view class="menu-icon">🚪</view>
            <text class="menu-label">退出登录</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>
  </block>

  <!-- 底部安全距离 -->
  <view class="safe-bottom" style="height: {{bottomSafeHeight > 0 ? bottomSafeHeight + 8 : 8}}px;"></view>
</scroll-view>
