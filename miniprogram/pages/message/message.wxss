/* 页面整体 */
page {
  background: #f5f5f5;
  height: 100%;
  overflow: hidden;
}

/* ========== 固定区域：导航栏 + 系统通知 + 搜索栏 ========== */
.fixed-top {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: white;
  z-index: 100;
}

/* 导航栏（在固定区域内，与首页一致） */
.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #e0e0e0;
}

.nav-title {
  font-size: 18px;
  font-weight: 600;
  color: #000;
}

/* 置顶系统通知 */
.pinned-notification {
  background: #f0f9ff;
  padding: 12px 16px;
  border-bottom: 1rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  gap: 10px;
}

.pinned-icon {
  width: 36px;
  height: 36px;
  background: #07C160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.pinned-bell {
  font-size: 18px;
}

.pinned-content {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.pinned-title {
  font-size: 14px;
  font-weight: 600;
  color: #000;
  margin-bottom: 2px;
  display: block;
}

.pinned-text {
  font-size: 12px;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.pinned-badge {
  background: #ff3b30;
  color: white;
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 8px;
  flex-shrink: 0;
}

/* 搜索栏（在固定区域内） */
.search-section {
  padding: 8px 16px 12px;
  background: white;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-bar {
  background: #f5f5f5;
  border-radius: 8px;
  padding: 8px 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.search-icon {
  font-size: 16px;
  flex-shrink: 0;
}

.search-placeholder {
  color: #999;
  font-size: 14px;
}

/* ========== 可滚动区域：消息列表 ========== */
.message-scroll {
  background: #f5f5f5;
}

/* 消息列表项 */
.message-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  background: white;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 14px;
}

.message-avatar {
  width: 52px;
  height: 52px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 20px;
  font-weight: 500;
  flex-shrink: 0;
}

.message-content {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6px;
}

.message-name {
  font-size: 16px;
  font-weight: 500;
  color: #000;
}

.message-time {
  font-size: 12px;
  color: #999;
}

.message-preview {
  font-size: 13px;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.unread-badge {
  background: #07C160;
  color: white;
  font-size: 11px;
  min-width: 18px;
  height: 18px;
  border-radius: 9px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 5px;
  flex-shrink: 0;
}

/* 底部安全距离 */
.safe-bottom {
  height: 20px;
}
