/* 页面整体 */
page {
  background: #f5f5f5;
  height: 100%;
  overflow: hidden;
}

/* ========== 固定区域 ========== */
.fixed-top {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: white;
  z-index: 1000;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #e0e0e0;
}

.nav-title {
  font-size: 18px;
  font-weight: 600;
  color: #000;
}

/* 搜索栏 */
.search-section {
  padding: 8px 16px 12px;
}

.search-bar {
  background: #f5f5f5;
  border-radius: 8px;
  padding: 8px 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.search-icon {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
}

.search-placeholder {
  color: #999;
  font-size: 14px;
}

/* 分类导航 - 两行网格 */
.category-section {
  padding: 16rpx 16rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: 20%;
  margin-bottom: 12rpx;
}

.category-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.category-name {
  font-size: 22rpx;
  color: #333;
}

/* ========== 可滚动区域 ========== */
.service-scroll {
  background: #f5f5f5;
}

/* 推荐服务标题 - 固定区域内 */
.section-header {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 12px 16px 12px;
  background: white;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 17px;
  font-weight: 600;
  color: #000;
}

.section-tab {
  font-size: 13px;
  color: #999;
}

.section-more {
  font-size: 13px;
  color: #999;
  margin-left: auto;
}

/* 服务卡片 */
.service-card {
  margin: 0 16px 16px 16px;
  background: white;
  border-radius: 16rpx;
  border: 0.5px solid #e0e0e0;
  overflow: hidden;
}

.card-inner {
  padding: 20rpx 24rpx;
  display: flex;
  gap: 20rpx;
}

.service-image {
  width: 100px;
  height: 100px;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 12px;
  flex-shrink: 0;
}

.service-info {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.service-title {
  font-size: 16px;
  font-weight: 600;
  color: #000;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8px;
  display: block;
}

.service-provider {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8px;
}

.provider-avatar {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 500;
  flex-shrink: 0;
}

.provider-name {
  font-size: 13px;
  color: #666;
}

.provider-rating {
  font-size: 12px;
  color: #ff9500;
}

.service-desc {
  font-size: 13px;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 10px;
  display: block;
}

.service-stats {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stats-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stat-item {
  font-size: 12px;
  color: #999;
}

.contact-btn {
  padding: 6px 16px;
  background: #07C160;
  color: white;
  border-radius: 14rpx;
  font-size: 13px;
}

/* 底部安全距离（tab bar高度约50px + 安全区） */
.safe-bottom {
  height: 40px;
}

/* 悬浮发布按钮（上移，不被tab挡住） */
.fab-button {
  position: fixed;
  bottom: 130px;
  right: 20px;
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: #07C160;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 12px rgba(7, 193, 96, 0.4);
  z-index: 100;
}

.fab-icon {
  width: 24px;
  height: 24px;
}
