<view class="tab-bar">
  <view 
    class="tab-item {{selected === 0 ? 'active' : ''}}" 
    bindtap="switchTab" 
    data-index="0"
  >
    <image 
      src="{{selected === 0 ? '/images/home-active.png' : '/images/home.png'}}" 
      class="tab-icon"
    ></image>
    <text class="tab-label">首页</text>
  </view>
  
  <view 
    class="tab-item {{selected === 1 ? 'active' : ''}}" 
    bindtap="switchTab" 
    data-index="1"
  >
    <view class="notification-dot" wx:if="{{messageCount > 0}}">
      <view class="dot"></view>
    </view>
    <image 
      src="{{selected === 1 ? '/images/message-active.png' : '/images/message.png'}}" 
      class="tab-icon"
    ></image>
    <text class="tab-label">消息</text>
  </view>
  
  <view 
    class="tab-item {{selected === 2 ? 'active' : ''}}" 
    bindtap="switchTab" 
    data-index="2"
  >
    <image 
      src="{{selected === 2 ? '/images/profile-active.png' : '/images/profile.png'}}" 
      class="tab-icon"
    ></image>
    <text class="tab-label">我的</text>
  </view>
</view>
