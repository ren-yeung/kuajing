<!-- 导航栏背景（填满顶部白色区域） -->
<view class="nav-bg" style="height: {{statusBarHeight + 32}}px;"></view>

<!-- 导航栏：与状态胶囊同高度 -->
<view class="nav-bar" style="top: {{statusBarHeight}}px; height: 32px;">
  <view class="nav-back" bindtap="goBack">
    <text class="back-icon">‹</text>
  </view>
  <text class="nav-title">{{chatName}}</text>
</view>

<!-- 聊天区域 -->
<scroll-view
  class="chat-container"
  style="top: {{statusBarHeight + 32}}px; bottom: {{keyboardHeight > 0 ? (keyboardHeight + 96) + 'px' : '120rpx'}};"
  scroll-y
  enhanced
  show-scrollbar="{{false}}"
  scroll-into-view="{{scrollIntoView}}"
  scroll-with-animation
  bindscrolltoupper="onScrollUp"
>
  <!-- 底部留白用于输入框弹出 -->
  <view style="height: 20rpx;"></view>
  
  <!-- 消息列表 -->
  <block wx:for="{{messages}}" wx:key="id">
    <!-- 消息间时间分隔（超过5分钟间隔） -->
    <view wx:if="{{item.timeDivider}}" class="time-divider">{{item.timeDivider}}</view>

    <view id="msg-{{item.id}}" class="message {{item.type === 'sent' ? 'sent' : 'received'}} {{item.mediaType === 'image' || item.mediaType === 'video' ? 'media-message' : ''}}">
      <!-- 对方头像（左侧） -->
      <view wx:if="{{item.type === 'received'}}" class="message-avatar" style="background: {{item.avatarBg}};">
        <text>{{item.avatarText}}</text>
      </view>
      
      <!-- 图片消息（无气泡包裹） -->
      <image wx:if="{{item.mediaType === 'image'}}" 
        class="message-image" 
        src="{{item.mediaUrl}}" 
        mode="aspectFit"
        bindtap="previewImage"
        data-url="{{item.mediaUrl}}"
      />
      
      <!-- 视频消息 -->
      <video wx:if="{{item.mediaType === 'video'}}" 
        class="message-video" 
        src="{{item.mediaUrl}}"
        controls
      />
      
      <!-- 文本消息气泡 -->
      <view wx:if="{{item.content && !item.mediaType}}" class="message-bubble">
        <text>{{item.content}}</text>
      </view>
      
      <!-- 发送者头像（右侧） -->
      <view wx:if="{{item.type === 'sent'}}" class="message-avatar sent-avatar">
        <text>我</text>
      </view>
    </view>
  </block>

  <!-- 底部留白 -->
  <view id="bottom" style="height: 20rpx;"></view>
</scroll-view>

<!-- 底部输入栏 -->
<view class="input-bar" style="bottom: {{keyboardHeight > 0 ? keyboardHeight + 'px' : 0}};">
  <input
    type="text"
    class="input-field"
    placeholder="输入消息..."
    value="{{inputText}}"
    bindinput="onInputChange"
    bindconfirm="sendMessage"
    bindfocus="onInputFocus"
    bindblur="onInputBlur"
    confirm-type="send"
    adjust-position="{{false}}"
  />
  <!-- 表情按钮（始终显示） -->
  <view class="btn-icon btn-emoji" bindtap="toggleEmoji">
    <text>😊</text>
  </view>
  <!-- 无文字：显示上传按钮 -->
  <view wx:if="{{!hasInput}}" class="btn-icon btn-add" bindtap="chooseMedia">
    <text>+</text>
  </view>
  <!-- 有文字：显示发送按钮 -->
  <view wx:if="{{hasInput}}" class="btn-send" bindtap="sendMessage">发送</view>
</view>

<!-- 表情面板 -->
<view wx:if="{{showEmoji}}" class="emoji-panel">
  <!-- TODO: 表情列表 -->
</view>
