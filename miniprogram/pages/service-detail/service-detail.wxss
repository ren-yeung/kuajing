/* service-detail.wxss */
page {
  height: 100%;
  background: #f5f5f5;
}

.page {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
  overflow: hidden;
}

/* 加载中提示 */
.loading-cover {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E5E5E5;
  border-top-color: #07C160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ========== 滚动内容区域 ========== */
.content-scroll {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  background: #f5f5f5;
}

.content-scroll::-webkit-scrollbar {
  display: none;
}

/* 服务图片 */
.service-image {
  width: 100%;
  height: 420rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 36rpx;
  position: relative;
}

/* 导航栏（绝对定位在容器内） */
.nav-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding-top: 88rpx;
}

.nav-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  background: rgba(0,0,0,0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 36rpx;
}

/* 服务信息卡片 */
.service-info-card {
  background: white;
  margin: -40rpx 0 0 0;
  border-radius: 32rpx 32rpx 0 0;
  padding: 64rpx 32rpx 20rpx;
  position: relative;
  z-index: 10;
}

.service-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.service-price {
  font-size: 48rpx;
  font-weight: 600;
  color: #ff6b35;
}

.price-unit {
  font-size: 28rpx;
  font-weight: 400;
}

.service-actions {
  display: flex;
  gap: 24rpx;
  align-items: center;
}

.action-item {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.service-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #000;
  margin-bottom: 24rpx;
  display: block;
}

.service-stats {
  display: flex;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #999;
}

/* 商家信息 */
.merchant-section {
  background: white;
  margin-top: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.merchant-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.merchant-info {
  flex: 1;
}

.merchant-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #000;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.verified-badge {
  font-size: 20rpx;
  background: #07C160;
  color: white;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.merchant-rating {
  font-size: 24rpx;
  color: #ff9500;
}

.follow-btn {
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.follow-btn.following {
  background: #f5f5f5;
  color: #999;
}

.follow-btn.not-following {
  background: #07C160;
  color: white;
}

/* 服务详情 */
.detail-section {
  background: white;
  margin-top: 16rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #000;
  margin-bottom: 24rpx;
  display: block;
}

.detail-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.detail-tags {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.detail-tag {
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
}

/* 评价区 */
.review-section {
  background: white;
  margin-top: 16rpx;
  padding: 32rpx;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.review-more {
  font-size: 26rpx;
  color: #999;
}

.review-item {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.review-item:last-child {
  border-bottom: none;
}

.review-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.review-content {
  flex: 1;
  min-width: 0;
}

.review-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.review-rating {
  font-size: 22rpx;
  color: #ff9500;
  margin-bottom: 12rpx;
  display: block;
}

.review-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: block;
}

.review-date {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
  display: block;
}

/* 底部安全距离 */
.safe-bottom {
  height: 40rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  gap: 24rpx;
  z-index: 100;
}

.bottom-left {
  display: flex;
  gap: 32rpx;
}

.bottom-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.bottom-action-icon {
  font-size: 40rpx;
}

.bottom-action-text {
  font-size: 20rpx;
  color: #999;
}

.contact-btn {
  flex: 1;
  padding: 20rpx;
  background: #07C160;
  color: white;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}
