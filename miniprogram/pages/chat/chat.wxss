/* 导航栏背景 */
.nav-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: white;
  z-index: 997;
}

/* 导航栏 */
.nav-bar {
  background: white;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  position: fixed;
  left: 0;
  right: 0;
  z-index: 999;
  border-bottom: 1rpx solid #f0f0f0;
  height: 100rpx;
}

.nav-back {
  width: 80rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #333;
  font-weight: bold;
}

.nav-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: 600;
  color: #000;
  text-align: center;
  margin-left: -60rpx;
}

.nav-actions {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.more-icon {
  font-size: 36rpx;
  color: #333;
}

/* 聊天区域 */
.chat-container {
  position: fixed;
  left: 0;
  right: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 32rpx 20rpx 16rpx 24rpx;
  background: #f5f5f5;
}

.chat-container::-webkit-scrollbar {
  display: none;
}

/* 时间分隔符 */
.time-divider {
  text-align: center;
  margin: 32rpx 0;
  font-size: 24rpx;
  color: #999;
}

/* 消息气泡 */
.message {
  display: flex;
  margin-bottom: 32rpx;
  align-items: flex-start;
  box-sizing: border-box;
}

/* 收到的消息：头像在左，文本在右（正常排列） */
.message.received {
  flex-direction: row;
}

/* 发送的消息：文本在左，头像在右（正常排列，不反转） */
.message.sent {
  flex-direction: row;
  justify-content: flex-end;
  padding-right: calc(28rpx + 2%);
  box-sizing: border-box;
}

.message-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  color: white;
  flex-shrink: 0;
}

.message.received .message-avatar {
  margin-right: 20rpx;
}

.message.sent .message-avatar {
  margin-left: 0;
  background: #07C160;
}

.message-bubble {
  max-width: 70%;
  padding: 20rpx 28rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  line-height: 1.4;
  word-wrap: break-word;
}

.message.received .message-bubble {
  background: white;
  color: #000;
  border-top-left-radius: 8rpx;
}

.message.sent .message-bubble {
  background: #95EC69;
  color: #000;
  border-top-right-radius: 8rpx;
}

/* 图片消息（无气泡包裹，按原图比例） */
.message-image {
  max-width: 400rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

/* 媒体消息时顶部对齐 */
.media-message {
  align-items: flex-start;
}

/* 视频消息 */
.message-video {
  width: 400rpx;
  height: 300rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

/* 底部输入栏 */
.input-bar {
  background: white;
  border-top: 1rpx solid #e0e0e0;
  padding: 12rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
}

.input-field {
  flex: 1;
  background: #f5f5f5;
  border: none;
  border-radius: 12rpx;
  padding: 14rpx 20rpx;
  font-size: 30rpx;
  outline: none;
  height: 72rpx;
  min-width: 0;
}

/* 圆形图标按钮（表情/加号） */
.btn-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 40rpx;
  line-height: 1;
}

.btn-emoji {
  background: transparent;
}

.btn-add {
  background: #f0f0f0;
  color: #333;
  font-size: 44rpx;
  font-weight: 300;
}

/* 发送按钮（有文字时显示） */
.btn-send {
  background: #07C160;
  color: white;
  border-radius: 12rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  min-width: 100rpx;
}

/* 表情面板 */
.emoji-panel {
  position: fixed;
  bottom: 96rpx;
  left: 0;
  right: 0;
  height: 400rpx;
  background: #f7f7f7;
  border-top: 1rpx solid #e0e0e0;
  z-index: 998;
}
